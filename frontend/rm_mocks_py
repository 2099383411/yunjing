#!/usr/bin/env python3
"""Remove all MOCK fallbacks across 7 pages"""
import os, re

pages_dir = "/root/yunjing/frontend_nextgen/src/pages"

# ===== 1. ReportsListPage =====
path = os.path.join(pages_dir, "ReportsListPage.tsx")
with open(path) as f:
    c = f.read()

c = c.replace(
    "const MOCK_REPORTS = [",
    "// MOCK_REMOVED: was const MOCK_REPORTS = ["
)
# Close the mock array
c = re.sub(r'const MOCK_REPORTS = \[.*?^\];', '', c, flags=re.DOTALL | re.MULTILINE)
# Better approach - delete between MOCK_REPORTS = [ and ];
c = re.sub(r'const MOCK_REPORTS = \[.*?\];', '', c, flags=re.DOTALL)
# Remove catch fallback
c = c.replace(
    ".catch(() => setData(MOCK_REPORTS))",
    ".catch(() => message.error(\"加载报告列表失败\"))"
)
# Change initial state
c = c.replace(
    "useState(MOCK_REPORTS)",
    "useState([])"
)
with open(path, 'w') as f:
    f.write(c)
print("1. ReportsListPage DONE")

# ===== 2. TaskListPage =====
path = os.path.join(pages_dir, "TaskListPage.tsx")
with open(path) as f:
    c = f.read()

c = re.sub(r'const MOCK_TASKS = \[.*?\];', '', c, flags=re.DOTALL)
c = c.replace(
    ".catch(() => { setData(MOCK_TASKS); })",
    ".catch(() => message.error(\"加载任务列表失败\"))"
)
c = c.replace(
    "useState(MOCK_TASKS)",
    "useState([])"
)
with open(path, 'w') as f:
    f.write(c)
print("2. TaskListPage DONE")

# ===== 3. PerceptionPage =====
path = os.path.join(pages_dir, "PerceptionPage.tsx")
with open(path) as f:
    c = f.read()

c = re.sub(r'const MOCK_ASSETS: Asset\[\] = \[.*?\];', '', c, flags=re.DOTALL)
c = c.replace(
    "useState<Asset[]>(MOCK_ASSETS)",
    "useState<Asset[]>([])"
)
# Also remove the mock constant reference
with open(path, 'w') as f:
    f.write(c)
print("3. PerceptionPage DONE")

# ===== 4. ReasoningPage =====
path = os.path.join(pages_dir, "ReasoningPage.tsx")
with open(path) as f:
    c = f.read()

c = re.sub(r'const MOCK_RECORDS: ReasoningRecord\[\] = \[.*?\];', '', c, flags=re.DOTALL)
c = c.replace(
    "useState<ReasoningRecord[]>(MOCK_RECORDS)",
    "useState<ReasoningRecord[]>([])"
)
# Also remove MOCK_STATS - check if it exists
if "MOCK_STATS" in c:
    c = re.sub(r'const MOCK_STATS = \{.*?\};', '', c, flags=re.DOTALL)
    c = c.replace(
        "useState(MOCK_STATS)",
        "useState({ passCount: 0, rejectCount: 0, pendingCount: 0, totalCount: 0 })"
    )
with open(path, 'w') as f:
    f.write(c)
print("4. ReasoningPage DONE")

# ===== 5. ApprovalWorkbenchPage =====
path = os.path.join(pages_dir, "ApprovalWorkbenchPage.tsx")
with open(path) as f:
    c = f.read()

# Already uses empty array in useState, just remove MOCK_DATA constant
c = re.sub(r'const MOCK_DATA: AuditRecord\[\] = \[.*?\];', '', c, flags=re.DOTALL)
with open(path, 'w') as f:
    f.write(c)
print("5. ApprovalWorkbenchPage DONE")

# ===== 6. OrchestrationPage =====
path = os.path.join(pages_dir, "OrchestrationPage.tsx")
with open(path) as f:
    c = f.read()

# Remove MOCK constants
c = re.sub(r'const MOCK_INITIAL_NODES: Node\[\] = \[.*?\];', '', c, flags=re.DOTALL)
c = re.sub(r'const MOCK_INITIAL_EDGES: Edge\[\] = \[.*?\];', '', c, flags=re.DOTALL)
# Replace state initializations with empty arrays
c = c.replace(
    "useNodesState(MOCK_INITIAL_NODES)",
    "useNodesState([])"
)
c = c.replace(
    "useEdgesState(MOCK_INITIAL_EDGES)",
    "useEdgesState([])"
)
# Remove the reset to mock
c = c.replace(
    "setNodes(MOCK_INITIAL_NODES);",
    "setNodes([]);"
)
c = c.replace(
    "setEdges(MOCK_INITIAL_EDGES);",
    "setEdges([]);"
)
with open(path, 'w') as f:
    f.write(c)
print("6. OrchestrationPage DONE")

# ===== 7. SettingsPage =====
path = os.path.join(pages_dir, "SettingsPage.tsx")
with open(path) as f:
    c = f.read()

# Remove all MOCK_* constants and their references
mocks_to_remove = [
    ("mockSysInfo", "const mockSysInfo = {"),
    ("mockLLMProviders", "const mockLLMProviders = ["),
    ("mockRoles", "const mockRoles = ["),
    ("mockNotifications", "const mockNotifications = ["),
    ("mockCredentials", "const mockCredentials = ["),
    ("mockAuditLogs", "const mockAuditLogs = ["),
    ("mockUpdates", "const mockUpdates = ["),
    ("mockReportTemplates", "const mockReportTemplates = ["),
]
for name, start in mocks_to_remove:
    # Remove the entire mock object/array
    c = re.sub(
        rf'const {re.escape(name)} = .*?;(?=\s*(const |/\*|\n\n|$))',
        f'const {name} = [] as const; // MOCK_REMOVED',
        c,
        flags=re.DOTALL
    )
# Also fix the inline mock return for objects
c = c.replace("mockSysInfo", "({version:\"-\"}) as any")
c = c.replace("mockReportTemplates", "([])")
c = c.replace("mockLLMProviders", "([])")
c = c.replace("mockRoles", "([])")
c = c.replace("mockNotifications", "([])")
c = c.replace("mockCredentials", "([])")
c = c.replace("mockAuditLogs", "([])")
c = c.replace("mockUpdates", "([])")

with open(path, 'w') as f:
    f.write(c)
print("7. SettingsPage DONE (partial - inline mocks still exist in sub-components)")

print("\n=== All mock removals complete ===")
