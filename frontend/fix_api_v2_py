# ==================== 3. OrchestrationPage ====================
print("=== OrchestrationPage ===")
path = os.path.join(pages_dir, "OrchestrationPage.tsx")
with open(path) as f:
    c = f.read()

if "useEffect" not in c:
    c = c.replace(
        'import { useState } from "react";',
        'import { useState, useEffect } from "react";'
    )
    old = "const [nodes, setNodes] = useState(MOCK_INITIAL_NODES);"
    new_text = """const [nodes, setNodes] = useState(MOCK_INITIAL_NODES);
  const [edges, setEdges] = useState(MOCK_INITIAL_EDGES);

  useEffect(() => {
    request.get("/dashboard/attack-chain").then(res => {
      if (res?.data?.chains?.length > 0) {
        const chains = res.data.chains;
        const newNodes = [];
        const newEdges = [];
        chains.forEach((chain, ci) => {
          const stages = chain.stages || chain.path || [];
          stages.forEach((stage, si) => {
            newNodes.push({
              id: "chain-" + ci + "-" + si,
              type: "default",
              position: { x: 250 + si * 220, y: 100 + ci * 120 },
              data: {
                label: stage.name || stage.stage || stage.action || "",
                phase: stage.phase || stage.evidence_type || "",
                status: stage.status || "completed",
                confidence: stage.confidence_after || stage.confidence || 0.5,
                detail: stage.description || stage.action || "",
              },
            });
            if (si > 0) {
              newEdges.push({
                id: "edge-" + ci + "-" + si,
                source: "chain-" + ci + "-" + (si-1),
                target: "chain-" + ci + "-" + si,
                animated: true,
              });
            }
          });
        });
        if (newNodes.length > 0) { setNodes(newNodes); setEdges(newEdges); }
      }
    }).catch(() => {});
  }, []);
"""
    if old in c:
        c = c.replace(old, new_text)
        with open(path, 'w') as f:
            f.write(c)
        print("  DONE")
    else:
        print("  FAIL: pattern not found")
else:
    print("  SKIP (already has useEffect)")

