  useEffect(() => {
    request.get("/reasoning/stats").then(res => {
      if (res?.data && res.data.sessions !== undefined) {
        setStats({
          passCount: res.data.success_count || 0,
          rejectCount: res.data.failed_count || 0,
          pendingCount: (res.data.total_steps || 0) - (res.data.success_count || 0) - (res.data.failed_count || 0),
          totalCount: res.data.total_steps || 0,
        });
      }
    }).catch(() => {});
    request.get("/tasks?limit=5").then(res => {
      const tasks = Array.isArray(res?.data) ? res.data : [];
      if (tasks.length > 0) return request.get("/reasoning/chain/" + tasks[0].id);
    }).then(res => {
      if (res?.data?.steps) {
        const steps = res.data.steps.map((s, i) => ({
          id: s.id || "step-" + i,
          step: i + 1,
          title: s.phase || s.evidence_type || s.action || "Step " + (i+1),
          description: s.reasoning || s.description || "",
          icon: null,
          evidences: [],
          confidence: Math.round((s.confidence_after || 0.5) * 100),
        }));
        if (steps.length > 0) setRecords(steps);
      }
    }).catch(() => {});
  }, []);
"""
    )
    with open(path, 'w') as f:
        f.write(c)
