for filename, fix in fixes.items():
    path = os.path.join(pages_dir, filename)
    print(f"=== {filename} ===")
    
    with open(path) as f:
        c = f.read()
    
    # Check if already has working API calls (look for request. + useEffect pattern)
    lines = c.split('\n')
    has_working_api = False
    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped.startswith('useEffect('):
            # Check if there's a request.get in the following lines
            for j in range(i, min(i+15, len(lines))):
                if 'request.get(' in lines[j]:
                    has_working_api = True
                    break
    
    if has_working_api:
        print("  SKIP (already has working API calls)")
        continue
    
    # Inject code after the component opening brace
    marker = fix["component_marker"]
    idx = c.find(marker)
    if idx < 0:
        print(f"  FAIL: marker '{marker}' not found")
        continue
    
    brace_pos = c.find("{", idx)
    if brace_pos < 0:
        print(f"  FAIL: opening brace not found")
        continue
    
    # Check if useEffect is actually called (not just imported)
    if "useEffect(" not in c:
        if "useEffect" in c:
            # Already imported but not used - OK
            pass
        elif 'import { useState } from "react";' in c:
            c = c.replace(
                'import { useState } from "react";',
                'import { useState, useEffect } from "react";'
            )
        else:
            # Try to find any react import
            c = c.replace(
                'from "react";',
                ', useEffect } from "react";',
                1
            )
    
    # Check if request is already imported
    if 'import request' not in c:
        # Find the first import statement and add after it
        lines = c.split('\n')
        first_import_end = None
        for i, line in enumerate(lines):
            if line.startswith('import ') and line.strip().endswith('";') or line.strip().endswith("'"):
                first_import_end = i + 1
        if first_import_end:
            lines.insert(first_import_end, 'import request from "../api/request";')
            c = '\n'.join(lines)
        else:
            c = 'import request from "../api/request";\n' + c
    
    c = c[:brace_pos+1] + fix["code_to_inject"] + c[brace_pos+1:]
    
    with open(path, 'w') as f:
        f.write(c)
    
    print("  DONE")

print("\nAll fixes applied!")
