# ============================================================
# 云镜 Agent — AI 智能体编排引擎
# 基础镜像: python:3.12-slim
# 轻量，不装任何渗透工具，仅负责 LLM 对话 + Function Calling
# 预计大小: ~500MB
# ============================================================

FROM python:3.12-slim

LABEL maintainer="yunjing team"
LABEL description="CloudMirror Agent - AI orchestration engine (LLM + Function Calling)"

# 阻止交互式提示
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# ─── 系统依赖 ───────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ─── Python 环境 ────────────────────────────────────────
WORKDIR /app

RUN pip install --upgrade pip setuptools wheel

# 安装依赖
COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

# ─── 应用代码 ───────────────────────────────────────────
COPY app/ /app/

# ─── 入口 ───────────────────────────────────────────────
EXPOSE 8001

CMD ["uvicorn", "agent_main:app", "--host", "0.0.0.0", "--port", "8001"]
ENV PYTHONPATH=/
